# Copy this file to .env and edit values as needed.

# Pre-filled default Google Sheet URL shown in the app UI.
DEFAULT_GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/1yGNy2hHN5kyMltyjmYUhrmjvzzEMYweGe9MeYex_Lls/edit?gid=245836030#gid=245836030

# Optional: path to OAuth desktop client JSON (fallback when ADC is not configured).
# GOOGLE_OAUTH_CLIENT_SECRET_FILE=/absolute/path/to/client_secret.json

# Optional: where OAuth user tokens are cached.
# GOOGLE_OAUTH_TOKEN_CACHE=~/.config/policy_eval_dashboard/google_oauth_token.json
